cssCopy/* ═══════════════════════════════════════════════
   ROOT & RESET
═══════════════════════════════════════════════ */
:root {
  --bg: #1e1e2e;
  --bg2: #252535;
  --bg3: #2d2d42;
  --bg4: #353550;
  --accent: #7c6af7;
  --accent2: #5a9cf6;
  --accent3: #50e3c2;
  --success: #49cc90;
  --warning: #fca130;
  --danger: #f93e3e;
  --text: #e4e4f0;
  --text2: #a0a0c0;
  --border: #3a3a55;
  --border2: #4a4a65;
  --shadow: 0 4px 20px rgba(0,0,0,0.4);
  --radius: 8px;
  --radius-sm: 4px;
  --font: 'Segoe UI', system-ui, sans-serif;
  --mono: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', monospace;
  --get: #61affe;
  --post: #49cc90;
  --put: #fca130;
  --patch: #50e3c2;
  --delete: #f93e3e;
  --head: #9012fe;
  --options: #0d5aa7;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  overflow: hidden;
}

/* ═══════════════════════════════════════════════
   TOP NAV
═══════════════════════════════════════════════ */
.topnav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 0 16px;
  height: 52px;
  flex-shrink: 0;
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  box-shadow: var(--shadow);
}

.logo {
  font-size: 18px;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: -0.5px;
}
.logo i { margin-right: 6px; }

.topnav-right { display: flex; gap: 4px; align-items: center; }

.btn-nav {
  background: transparent;
  border: 1px solid transparent;
  color: var(--text2);
  padding: 6px 14px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 13px;
  transition: all .2s;
  display: flex; align-items: center; gap: 6px;
}
.btn-nav:hover, .btn-nav.active {
  background: var(--bg3);
  color: var(--text);
  border-color: var(--border);
}
.btn-export { color: var(--accent3); }
.btn-import { color: var(--accent2); cursor: pointer; }

/* ═══════════════════════════════════════════════
   PROXY STATUS BAR
═══════════════════════════════════════════════ */
.proxy-statusbar {
  position: fixed;
  top: 52px; left: 0; right: 0;
  height: 28px;
  background: var(--bg3);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 16px;
  font-size: 12px;
  color: var(--text2);
  z-index: 99;
}
#proxyStatusDot { font-size: 8px; color: var(--text2); }
#proxyStatusDot.active { color: var(--warning); animation: pulse 1.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
#proxyStatusInfo { color: var(--warning); font-weight: 600; }

/* ═══════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════ */
.layout {
  display: flex;
  height: calc(100vh - 80px);
  margin-top: 80px;
  overflow: hidden;
}

/* SIDEBAR */
.sidebar {
  width: 240px;
  flex-shrink: 0;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}
.sidebar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 12px;
  border-bottom: 1px solid var(--border);
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: var(--text2);
  position: sticky; top: 0;
  background: var(--bg2);
}

.sidebar-collection {
  padding: 0;
}
.sidebar-coll-header {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 7px 12px;
  cursor: pointer;
  font-size: 13px;
  border-bottom: 1px solid var(--border);
  background: var(--bg3);
  font-weight: 600;
  transition: background .15s;
}
.sidebar-coll-header:hover { background: var(--bg4); }
.sidebar-coll-header i { color: var(--warning); font-size: 12px; }

.sidebar-req {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 5px 16px 5px 28px;
  cursor: pointer;
  font-size: 12px;
  border-bottom: 1px solid rgba(255,255,255,.03);
  transition: background .15s;
}
.sidebar-req:hover { background: var(--bg4); }
.method-badge {
  font-size: 10px;
  font-weight: 700;
  padding: 2px 5px;
  border-radius: 3px;
  background: var(--bg4);
  min-width: 42px;
  text-align: center;
}
.method-GET { color: var(--get); }
.method-POST { color: var(--post); }
.method-PUT { color: var(--put); }
.method-PATCH { color: var(--patch); }
.method-DELETE { color: var(--delete); }
.method-HEAD { color: var(--head); }
.method-OPTIONS { color: var(--options); }

/* MAIN CONTENT */
.content {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.page { display: none; flex-direction: column; height: 100%; }
.page.active { display: flex; }

/* ═══════════════════════════════════════════════
   REQUEST BAR
═══════════════════════════════════════════════ */
.request-bar {
  display: flex;
  gap: 8px;
  padding: 10px 16px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  align-items: center;
  flex-shrink: 0;
}

.method-select {
  background: var(--bg3);
  border: 1px solid var(--border);
  color: var(--accent);
  padding: 8px 10px;
  border-radius: var(--radius-sm);
  font-weight: 700;
  cursor: pointer;
  font-size: 13px;
  outline: none;
}
.method-select:focus { border-color: var(--accent); }

.url-input {
  flex: 1;
  background: var(--bg3);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 8px 12px;
  border-radius: var(--radius-sm);
  font-size: 14px;
  font-family: var(--mono);
  outline: none;
  transition: border .2s;
}
.url-input:focus { border-color: var(--accent); }

.env-select {
  background: var(--bg3);
  border: 1px solid var(--border);
  color: var(--text2);
  padding: 8px 10px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  outline: none;
  font-size: 12px;
  min-width: 130px;
}

.btn-send {
  background: var(--accent);
  color: white;
  border: none;
  padding: 8px 20px;
  border-radius: var(--radius-sm);
  font-weight: 700;
  cursor: pointer;
  font-size: 14px;
  display: flex; align-items: center; gap: 6px;
  transition: all .2s;
  white-space: nowrap;
}
.btn-send:hover { background: #6a57e0; transform: translateY(-1px); }
.btn-send:active { transform: translateY(0); }

.btn-save {
  background: var(--bg3);
  color: var(--text2);
  border: 1px solid var(--border);
  padding: 8px 14px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 13px;
  display: flex; align-items: center; gap: 6px;
  transition: all .2s;
  white-space: nowrap;
}
.btn-save:hover { background: var(--bg4); color: var(--text); }

/* ═══════════════════════════════════════════════
   REQUEST TABS
═══════════════════════════════════════════════ */
.req-tabs {
  display: flex;
  gap: 0;
  padding: 0 16px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.req-tab {
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--text2);
  padding: 10px 14px;
  cursor: pointer;
  font-size: 13px;
  transition: all .15s;
  white-space: nowrap;
}
.req-tab:hover { color: var(--text); }
.req-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.badge {
  background: var(--bg4);
  color: var(--text2);
  font-size: 10px;
  padding: 1px 5px;
  border-radius: 10px;
  margin-left: 4px;
}

.req-tab-content {
  display: none;
  flex-direction: column;
  flex: 1;
  overflow-y: auto;
  padding: 0;
}
.req-tab-content.active { display: flex; }

/* ═══════════════════════════════════════════════
   KV TABLE (params, headers, form)
═══════════════════════════════════════════════ */
.kv-table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 16px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: var(--text2);
  background: var(--bg2);
