  height: 100%;
  display: flex; align-items: center; justify-content: center;
  transition: color .15s;
}
.btn-del-row:hover { color: var(--danger); }

.form-kv-row {
  grid-template-columns: 30px 1fr 1fr 36px;
}

/* ═══════════════════════════════════════════════
   BODY AREA
═══════════════════════════════════════════════ */
.body-types {
  display: flex;
  gap: 16px;
  padding: 10px 16px;
  background: var(--bg2);
